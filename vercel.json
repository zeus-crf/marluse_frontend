{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "ng build --configuration production",
  "outputDirectory": "dist/marluse-frontend/browser",
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://marlusebackend-production.up.railway.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
